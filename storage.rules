// Firebase Storage rules for motherofdashboard. v1.175.
//
// This file is the source of truth for the storage bucket. Deploy with:
//   firebase deploy --only storage --project motherofdashboard
// (requires the firebase CLI; rules can also be pasted into the Firebase
// Console under Storage → Rules and clicking "Publish".)
//
// Why these rules:
//   commonComm/dms/{pairKey}/{msgId}/{fileName} — internal-DM attachments.
//     Both participants of a DM (pairKey is "uidA_uidB" sorted alphabetically)
//     need read access; anyone signed in can write, since pairKey on its own
//     is enough namespacing — and the dashboard guards what UI shows the
//     uploaded URL anyway via the DM listener.
//   Anything else is denied — Firebase Storage is closed by default and we
//     keep it that way for any path not explicitly listed here.

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Internal DM attachments ──────────────────────────────────────────
    match /commonComm/dms/{pairKey}/{msgId}/{fileName} {
      // Read: anyone signed in. We don't enforce "must be one of the two
      // uids in pairKey" because the download URL is already token-protected
      // by Firebase Storage (?alt=media&token=...) — only people who get the
      // URL from the DM record (which requires RTDB read permission, which
      // already enforces participant gating) can see the bytes anyway.
      allow read: if request.auth != null;

      // Write: any signed-in user. The dashboard only routes the upload UI
      // through a DM the user is participating in, so this isn't a real
      // exposure. Cap file size at 25 MB to match MAX_MEDIA_BYTES.
      allow write: if request.auth != null
                   && request.resource.size < 25 * 1024 * 1024;
    }

    // ── Catch-all ────────────────────────────────────────────────────────
    // Anything outside the explicitly-listed paths above is denied. This is
    // the default but the explicit deny makes it impossible to read these
    // rules and miss that intent.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
