<?xml version="1.0" encoding="utf-8"?>
<!-- Tile rendered by RemoteViews. RemoteViews only allows a fixed set of
     widgets (TextView, ImageView, LinearLayout, etc.) and a few attribute
     types — keep this minimal. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/quick_note_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#008069"
    android:padding="12dp">

    <ImageView
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_quick_note"
        android:contentDescription="@null"
        android:tint="#FFFFFF" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Quick Note"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="Tap to dictate"
        android:textColor="#E0FFFFFF"
        android:textSize="11sp" />
</LinearLayout>
