<?xml version="1.0" encoding="utf-8"?>
<!--
  Unread-indicator dot for the widget tiles. Pink to match the in-app
  notification badge and the app-icon dot the user sees on the home
  screen. Drawn as a perfect circle; thin white outline gives a hair of
  separation against the green tile background so the dot stays visible
  even on edge-case launchers that recolor backgrounds.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <solid android:color="#EC4899" />
    <stroke android:width="1dp" android:color="#FFFFFF" />
    <size android:width="10dp" android:height="10dp" />
</shape>
