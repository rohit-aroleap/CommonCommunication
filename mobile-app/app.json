{
  "expo": {
    "name": "CommonCommunication",
    "slug": "commoncomm-mobile",
    "scheme": "commoncomm",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#008069"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "bundleIdentifier": "com.aroleap.commoncomm",
      "supportsTablet": false,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.aroleap.commoncomm",
      "adaptiveIcon": {
        "backgroundColor": "#008069"
      },
      "permissions": [
        "NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "READ_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "READ_MEDIA_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Attach images and videos to customer chats",
          "cameraPermission": "Take a photo to send to a customer"
        }
      ],
      [
        "expo-document-picker",
        { "iCloudContainerEnvironment": "Production" }
      ],
      [
        "expo-notifications",
        {
          "color": "#008069"
        }
      ]
    ],
    "extra": {
      "eas": { "projectId": "REPLACE_WITH_EAS_PROJECT_ID" },
      "googleSignIn": {
        "iosClientId": "REPLACE_WITH_IOS_OAUTH_CLIENT_ID",
        "androidClientId": "REPLACE_WITH_ANDROID_OAUTH_CLIENT_ID",
        "webClientId": "REPLACE_WITH_WEB_OAUTH_CLIENT_ID"
      },
      "workerUrl": "https://common-communication.rohitpatel-mailid297.workers.dev"
    }
  }
}
