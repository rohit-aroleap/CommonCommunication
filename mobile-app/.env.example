# Copy this file to `.env` and fill in the values. `.env` is gitignored.
# These end up in app.config.js → Constants.expoConfig.extra → config.ts.
#
# Where to get each value:
#   GOOGLE_*_CLIENT_ID
#     Firebase Console → Project settings → Your apps → (each platform).
#     Auth uses these via expo-auth-session/providers/google.
#   EAS_PROJECT_ID
#     Run `eas init` from mobile-app/ — it'll print the projectId. Or look
#     up an existing project at https://expo.dev/accounts/<you>/projects.
#   WORKER_URL
#     Optional override of the Cloudflare Worker URL. Defaults to the
#     production worker if unset.

GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_WEB_CLIENT_ID=
EAS_PROJECT_ID=
# WORKER_URL=
