node_modules/
.expo/
dist/
web-build/
*.log
.env
.env.local
android/
ios/
# Hand-written widget source lives under widget/{ios,android}/ and must
# be tracked — the patterns above would otherwise match those subtrees
# (gitignore matches at any depth without a leading slash).
!widget/ios/
!widget/android/
!widget/ios/**
!widget/android/**
# Local Expo modules (modules/<name>/android/...) also need negation —
# the blanket `android/` rule above would otherwise hide the Kotlin
# source, build.gradle, and manifest. v1.139: widget-updater module
# pushes home-screen widget dot counts from JS.
!modules/
!modules/**
.DS_Store
coverage/
GoogleService-Info.plist
google-services.json
credentials.json
